#include<stdio.h>

prime(a,b);

prime(a,b)
{
	if (b==1)
	{
		return 1;
	}
	else 
	{
		if (a%b==0)
		{
			return 0;
		}
		else 
		{
			return prime(a,b-1);
		}
	}
}
 
 int main()
 {
 	int a,x;
 	printf("enter a number: ");
 	scanf("%d",&a);
 	x=prime(a,a/2);
